# Desktop OAuth credentials for Google Drive sync.
#
# Create an OAuth Client ID of type "Desktop application" in Google Cloud
# Console for the project that hosts the app's OAuth consent screen, then
# copy the values here. The Linux build won't show the Sync section in
# Settings until both keys are filled.
#
# https://console.cloud.google.com/apis/credentials
#
# These get bundled into the app binary at build time. For desktop OAuth
# clients Google explicitly states the secret is not confidential, but
# we still keep it out of source control.
RSVP_OAUTH_CLIENT_ID=
RSVP_OAUTH_CLIENT_SECRET=
